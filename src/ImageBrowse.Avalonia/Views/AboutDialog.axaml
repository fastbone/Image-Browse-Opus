<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageBrowse.Views.AboutDialog"
        Title="About Image Browse"
        Width="440" MinHeight="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <ScrollViewer MaxHeight="520" HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="10">
            <TextBlock Text="&#x1F5BC;" FontSize="48" HorizontalAlignment="Center" />
            <TextBlock Text="Image Browse" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="VersionText" FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Cross-platform image browser (Avalonia)" FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
            <TextBlock Text="Shared Image Browse core with Magick.NET, MetadataExtractor, CommunityToolkit.Mvvm, Microsoft.Data.Sqlite, LibVLCSharp (video), and Velopack (updates where the platform supports it)."
                       FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" />

            <TextBlock x:Name="UpdateStatusText" Text="" FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" IsVisible="False" />

            <Button x:Name="CheckUpdatesButton" Margin="0,4,0,0" Content="Check for updates"
                    Padding="12,8" HorizontalAlignment="Center" Click="CheckUpdates_Click" />

            <StackPanel Spacing="4" Margin="0,8,0,0">
                <TextBlock Text="Project site" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="fastbone.github.io/Image-Browse-Opus"
                           FontSize="12" Foreground="{DynamicResource SystemControlAccentBrush}"
                           Cursor="Hand" TextDecorations="Underline"
                           HorizontalAlignment="Center"
                           PointerPressed="SiteLink_OnPointerPressed" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Source" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="github.com/fastbone/Image-Browse-Opus"
                           FontSize="12" Foreground="{DynamicResource SystemControlAccentBrush}"
                           Cursor="Hand" TextDecorations="Underline"
                           HorizontalAlignment="Center"
                           PointerPressed="RepoLink_OnPointerPressed" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="License" FontSize="12" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="GNU General Public License v3.0"
                           FontSize="12" Foreground="{DynamicResource SystemControlAccentBrush}"
                           Cursor="Hand" TextDecorations="Underline"
                           HorizontalAlignment="Center"
                           PointerPressed="LicenseLink_OnPointerPressed" />
            </StackPanel>

            <Button Margin="0,16,0,0" Content="Close" Width="90" Padding="12,8"
                    HorizontalAlignment="Center" Click="Close_Click" />
        </StackPanel>
    </ScrollViewer>
</Window>
