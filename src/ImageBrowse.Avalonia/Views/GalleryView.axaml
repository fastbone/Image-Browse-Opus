<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ImageBrowse.Models;assembly=ImageBrowse.Core"
             xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
             x:Class="ImageBrowse.Views.GalleryView"
             x:Name="GalleryRoot"
             x:CompileBindings="False"
             Focusable="True">

    <UserControl.Resources>
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />
    </UserControl.Resources>

    <Grid>
        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="False">
            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="No media in this folder" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="Browse to a folder containing images or videos" FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Gallery -->
        <ListBox x:Name="GalleryListBox"
                 ItemsSource="{Binding SortedImages}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 SelectionMode="Multiple"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 DoubleTapped="GalleryListBox_DoubleTapped"
                 KeyDown="GalleryListBox_KeyDown">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="Padding" Value="4" />
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="models:ImageItem">
                    <Grid Width="{Binding #GalleryRoot.DataContext.ThumbnailSize}" Margin="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding #GalleryRoot.DataContext.ThumbnailSize}" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Thumbnail area -->
                        <Border Grid.Row="0" CornerRadius="6" ClipToBounds="True"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                            <Panel>
                                <!-- Parent folder icon -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsVisible="{Binding IsParentFolder}">
                                    <TextBlock Text="⬆" FontSize="36"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text=".." FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Thumbnail image -->
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                       IsVisible="{Binding !IsParentFolder}" />

                                <!-- Loading shimmer -->
                                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                        CornerRadius="4" Margin="12"
                                        IsVisible="{Binding IsThumbnailLoading}"
                                        Opacity="0.5" />

                                <!-- Video play icon -->
                                <Border Background="#88000000" Width="36" Height="36"
                                        CornerRadius="18"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsHitTestVisible="False"
                                        IsVisible="{Binding IsVideo}">
                                    <TextBlock Text="▶" FontSize="16" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="2,0,0,0" />
                                </Border>

                                <!-- Video duration badge -->
                                <Panel IsVisible="{Binding IsVideo}">
                                    <Border Background="#CC000000" CornerRadius="4"
                                            Padding="5,2" Margin="0,0,6,6"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="{Binding DurationDisplay}" FontSize="10"
                                                   Foreground="White" FontWeight="Medium" />
                                    </Border>
                                </Panel>

                                <!-- Tag indicator -->
                                <Border Background="{DynamicResource SystemAccentColor}"
                                        CornerRadius="8" Padding="5,2" Margin="6"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        IsVisible="{Binding IsTagged}">
                                    <TextBlock Text="🏷" FontSize="10" Foreground="White" />
                                </Border>

                                <!-- Rating stars -->
                                <Border Padding="4,2" Margin="4,0,0,4"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        IsVisible="{Binding Rating, Converter={x:Static helpers:BoolToOpacityConverter.Instance}}">
                                    <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                               FontSize="10" Foreground="Gold" />
                                </Border>

                                <!-- Folder badge -->
                                <Panel IsVisible="{Binding IsFolder}">
                                    <Border Background="#CC000000" CornerRadius="10"
                                            VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                            Padding="10,4" Margin="0,0,0,6"
                                            IsVisible="{Binding !IsParentFolder}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" FontSize="11" Margin="0,0,4,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Folder" FontSize="11" Foreground="White"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Panel>
                            </Panel>
                        </Border>

                        <!-- File name -->
                        <TextBlock Grid.Row="1" Text="{Binding FileName}"
                                   FontSize="11" TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                   MaxWidth="{Binding #GalleryRoot.DataContext.ThumbnailSize}" />

                        <!-- Sort subtitle -->
                        <TextBlock Grid.Row="2" Text="{Binding SortSubtitleDisplay}"
                                   FontSize="10"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center" Margin="0,1,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
