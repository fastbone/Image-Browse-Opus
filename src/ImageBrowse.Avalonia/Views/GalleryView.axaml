<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ImageBrowse.Models;assembly=ImageBrowse.Core"
             xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
             xmlns:repeater="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
             x:Class="ImageBrowse.Views.GalleryView"
             x:Name="GalleryRoot"
             x:CompileBindings="False"
             Focusable="True">

    <UserControl.Styles>
        <Style Selector="Border.galleryTile.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.shimmerPulse">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="Infinite" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.35" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.65" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />
        <MenuFlyout x:Key="GalleryItemMenuFlyout" Placement="BottomEdgeAlignedLeft"
                    Opened="GalleryMenuFlyout_Opened">
            <MenuItem Header="Open in Fullscreen" Click="ContextOpen_Click" />
            <MenuItem Header="Rate">
                <MenuItem Header="★ 1" Click="ContextRate1_Click" />
                <MenuItem Header="★★ 2" Click="ContextRate2_Click" />
                <MenuItem Header="★★★ 3" Click="ContextRate3_Click" />
                <MenuItem Header="★★★★ 4" Click="ContextRate4_Click" />
                <MenuItem Header="★★★★★ 5" Click="ContextRate5_Click" />
                <MenuItem Header="Clear Rating" Click="ContextRate0_Click" />
            </MenuItem>
            <MenuItem Header="Toggle Tag" Click="ContextToggleTag_Click" />
            <MenuItem Header="Rename" Click="ContextRename_Click" />
            <MenuItem Header="Move to…" Click="ContextMove_Click" />
            <MenuItem Header="Copy to…" Click="ContextCopy_Click" />
            <MenuItem Header="Delete" Click="ContextDelete_Click" />
            <MenuItem Header="Show in File Manager" Click="ContextShowInExplorer_Click" />
            <MenuItem Header="Refresh Thumbnail" Click="ContextRefreshThumb_Click" />
        </MenuFlyout>
    </UserControl.Resources>

    <Grid>
        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="False">
            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="No media in this folder" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="Browse to a folder containing images or videos" FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer x:Name="GalleryScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent"
                      Focusable="True"
                      KeyDown="GalleryScroll_KeyDown"
                      DoubleTapped="GalleryScroll_DoubleTapped">
            <repeater:ItemsRepeater x:Name="GalleryRepeater"
                                    ItemsSource="{Binding SortedImages}"
                                    Margin="4">
                <repeater:ItemsRepeater.ItemTemplate>
                    <DataTemplate DataType="models:ImageItem">
                        <Border Classes="galleryTile" Margin="4" Padding="4" CornerRadius="8"
                                Background="Transparent"
                                PointerPressed="GalleryTile_PointerPressed"
                                PointerMoved="GalleryTile_PointerMoved"
                                PointerReleased="GalleryTile_PointerReleased"
                                DoubleTapped="GalleryTile_DoubleTapped"
                                ContextFlyout="{StaticResource GalleryItemMenuFlyout}">
                            <Grid Width="{Binding #GalleryRoot.DataContext.ThumbnailSize}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="{Binding #GalleryRoot.DataContext.ThumbnailSize}" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="6" ClipToBounds="True"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                    <Panel>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    IsVisible="{Binding IsParentFolder}">
                                            <TextBlock Text="⬆" FontSize="36"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text=".." FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>

                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                               IsVisible="{Binding !IsParentFolder}" />

                                        <Border Classes="shimmerPulse"
                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                CornerRadius="4" Margin="12"
                                                IsVisible="{Binding IsThumbnailLoading}" />

                                        <Border Background="#88000000" Width="36" Height="36"
                                                CornerRadius="18"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                IsHitTestVisible="False"
                                                IsVisible="{Binding IsVideo}">
                                            <TextBlock Text="▶" FontSize="16" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="2,0,0,0" />
                                        </Border>

                                        <Panel IsVisible="{Binding IsVideo}">
                                            <Border Background="#CC000000" CornerRadius="4"
                                                    Padding="5,2" Margin="0,0,6,6"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="{Binding DurationDisplay}" FontSize="10"
                                                           Foreground="White" FontWeight="Medium" />
                                            </Border>
                                        </Panel>

                                        <Border Background="{DynamicResource SystemAccentColor}"
                                                CornerRadius="8" Padding="5,2" Margin="6"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                IsVisible="{Binding IsTagged}">
                                            <TextBlock Text="🏷" FontSize="10" Foreground="White" />
                                        </Border>

                                        <Border Padding="4,2" Margin="4,0,0,4"
                                                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                IsVisible="{Binding Rating, Converter={x:Static helpers:BoolToOpacityConverter.Instance}}">
                                            <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                                       FontSize="10" Foreground="Gold" />
                                        </Border>

                                        <Panel IsVisible="{Binding IsFolder}">
                                            <Border Background="#CC000000" CornerRadius="10"
                                                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                    Padding="10,4" Margin="0,0,0,6"
                                                    IsVisible="{Binding !IsParentFolder}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📁" FontSize="11" Margin="0,0,4,0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="Folder" FontSize="11" Foreground="White"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Panel>
                                    </Panel>
                                </Border>

                                <TextBlock Grid.Row="1" Classes="gallery-filename"
                                           Text="{Binding FileName}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"
                                           MaxWidth="{Binding #GalleryRoot.DataContext.ThumbnailSize}" />

                                <TextBlock Grid.Row="2" Text="{Binding SortSubtitleDisplay}"
                                           FontSize="10"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           HorizontalAlignment="Center" Margin="0,1,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </repeater:ItemsRepeater.ItemTemplate>
            </repeater:ItemsRepeater>
        </ScrollViewer>
    </Grid>
</UserControl>
