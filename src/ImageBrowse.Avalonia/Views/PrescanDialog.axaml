<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageBrowse.Views.PrescanDialog"
        Title="Prescan Folder"
        Width="560" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Prescan Folder" FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,20" />

        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <TextBlock Text="Folder to Prescan" FontWeight="SemiBold" FontSize="13" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="FolderBox" Grid.Column="0" VerticalContentAlignment="Center" />
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0" Padding="12,6"
                            Click="BrowseFolder_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel Spacing="8">
                <TextBlock Text="Scan Depth" FontWeight="SemiBold" FontSize="13" />
                <ComboBox x:Name="DepthCombo" Width="200" HorizontalAlignment="Left" SelectedIndex="2">
                    <ComboBoxItem Content="This folder only" Tag="0" />
                    <ComboBoxItem Content="1 level deep" Tag="1" />
                    <ComboBoxItem Content="2 levels deep" Tag="2" />
                    <ComboBoxItem Content="5 levels deep" Tag="5" />
                    <ComboBoxItem Content="Unlimited" Tag="-1" />
                </ComboBox>
            </StackPanel>
        </Border>

        <ProgressBar x:Name="ProgressBar" Grid.Row="3" Height="6" Minimum="0" Maximum="100"
                     Margin="0,0,0,8" />

        <TextBlock x:Name="CurrentFolderText" Grid.Row="4" FontSize="11"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
        <TextBlock x:Name="StatsText" Grid.Row="5" FontSize="12" Margin="0,0,0,8" />

        <TextBlock x:Name="StatusLabel" Grid.Row="6" FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Bottom" Margin="0,0,0,12" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="StartButton" Content="Start Prescan" Width="130" Padding="12,8"
                    Click="StartButton_Click" />
            <Button x:Name="CloseButton" Content="Close" Width="80" Padding="8,8"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
