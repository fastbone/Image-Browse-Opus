<Window x:Class="ImageBrowse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ImageBrowse.Views"
        xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
        xmlns:models="clr-namespace:ImageBrowse.Models;assembly=ImageBrowse.Core"
        xmlns:branding="clr-namespace:ImageBrowse;assembly=ImageBrowse.Core"
        Title="{x:Static branding:AppBranding.DisplayName}" Width="1400" Height="900"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterScreen"
        MinWidth="800" MinHeight="500"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                BorderThickness="0" Padding="8,6" Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270" Color="Black" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Toggle folder -->
                    <ColumnDefinition Width="Auto" />  <!-- Sep -->
                    <ColumnDefinition Width="Auto" />  <!-- Back/Forward -->
                    <ColumnDefinition Width="Auto" />  <!-- Sep -->
                    <ColumnDefinition Width="*" />     <!-- Address bar -->
                    <ColumnDefinition Width="Auto" />  <!-- Sep -->
                    <ColumnDefinition Width="Auto" />  <!-- Sort -->
                    <ColumnDefinition Width="Auto" />  <!-- Sep -->
                    <ColumnDefinition Width="Auto" />  <!-- Thumbnail size -->
                    <ColumnDefinition Width="Auto" />  <!-- Sep -->
                    <ColumnDefinition Width="Auto" />  <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Folder tree toggle -->
                <Button Grid.Column="0" ToolTip="Toggle Folder Tree (Ctrl+Shift+F)"
                        AutomationProperties.Name="Toggle Folder Tree"
                        Style="{DynamicResource ToolbarButton}" Margin="2,0"
                        Command="{Binding ToggleFolderTreeCommand}">
                    <TextBlock Text="&#xED41;" FontFamily="{DynamicResource IconFont}" FontSize="16" />
                </Button>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BorderBrush}"
                           Margin="6,4" VerticalAlignment="Stretch" />

                <!-- Navigation -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BackButton" ToolTip="Back (Alt+Left)"
                            AutomationProperties.Name="Navigate Back"
                            Style="{DynamicResource ToolbarButton}"
                            Click="BackButton_Click">
                        <TextBlock Text="&#xE72B;" FontFamily="{DynamicResource IconFont}" FontSize="14" />
                    </Button>
                    <Button x:Name="ForwardButton" ToolTip="Forward (Alt+Right)"
                            AutomationProperties.Name="Navigate Forward"
                            Style="{DynamicResource ToolbarButton}"
                            Click="ForwardButton_Click">
                        <TextBlock Text="&#xE72A;" FontFamily="{DynamicResource IconFont}" FontSize="14" />
                    </Button>
                    <Button x:Name="UpButton" ToolTip="Up (Alt+Up)"
                            AutomationProperties.Name="Navigate Up"
                            Style="{DynamicResource ToolbarButton}"
                            Click="UpButton_Click">
                        <TextBlock Text="&#xE74A;" FontFamily="{DynamicResource IconFont}" FontSize="14" />
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="3" Width="1" Fill="{DynamicResource BorderBrush}"
                           Margin="6,4" VerticalAlignment="Stretch" />

                <!-- Address bar: breadcrumb mode + edit mode -->
                <Grid Grid.Column="4" Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xED25;" FontFamily="{DynamicResource IconFont}"
                               FontSize="13" Foreground="{DynamicResource FgMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />

                    <!-- Breadcrumb mode -->
                    <Border Grid.Column="1" x:Name="BreadcrumbBar"
                            Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="4,3" Cursor="Hand"
                            MouseLeftButtonDown="BreadcrumbBar_MouseLeftButtonDown">
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="BreadcrumbItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Edit mode (hidden by default) -->
                    <TextBox Grid.Column="1" x:Name="AddressBar"
                             AutomationProperties.Name="Folder Path"
                             Style="{DynamicResource AddressBar}"
                             Visibility="Collapsed"
                             Text="{Binding CurrentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="AddressBar_KeyDown"
                             LostFocus="AddressBar_LostFocus"
                             VerticalContentAlignment="Center" />
                </Grid>

                <!-- Separator -->
                <Rectangle Grid.Column="5" Width="1" Fill="{DynamicResource BorderBrush}"
                           Margin="6,4" VerticalAlignment="Stretch" />

                <!-- Sort controls (segmented pill) -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="4,0"
                            VerticalAlignment="Center">
                    <Border Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="1">
                        <StackPanel x:Name="SortSegments" Orientation="Horizontal">
                            <RadioButton x:Name="SortName" Content="Name" Tag="{x:Static models:SortField.FileName}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         IsChecked="True" Click="SortSegment_Click" />
                            <RadioButton Content="Modified" Tag="{x:Static models:SortField.DateModified}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Created" Tag="{x:Static models:SortField.DateCreated}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Taken" Tag="{x:Static models:SortField.DateTaken}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Size" Tag="{x:Static models:SortField.FileSize}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Dims" Tag="{x:Static models:SortField.Dimensions}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Type" Tag="{x:Static models:SortField.FileType}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                            <RadioButton Content="Rating" Tag="{x:Static models:SortField.Rating}"
                                         GroupName="SortField" Style="{DynamicResource SortSegmentButton}"
                                         Click="SortSegment_Click" />
                        </StackPanel>
                    </Border>
                    <Button ToolTip="Reset to default sort"
                            AutomationProperties.Name="Reset Sort"
                            Style="{DynamicResource ToolbarButton}" Margin="2,0"
                            Visibility="{Binding HasCustomFolderSort, Converter={StaticResource BoolToVis}}"
                            Click="ResetSortButton_Click">
                        <TextBlock Text="&#xE72C;" FontFamily="{DynamicResource IconFont}" FontSize="14" />
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="7" Width="1" Fill="{DynamicResource BorderBrush}"
                           Margin="6,4" VerticalAlignment="Stretch" />

                <!-- Thumbnail size slider -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" Margin="4,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#xE80A;" FontFamily="{DynamicResource IconFont}" FontSize="11"
                               Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center"
                               Margin="0,0,4,0" ToolTip="Small thumbnails" />
                    <Slider x:Name="ThumbnailSlider" Width="80" Minimum="80" Maximum="400"
                            AutomationProperties.Name="Thumbnail Size"
                            SmallChange="40" LargeChange="40" IsSnapToTickEnabled="True" TickFrequency="40"
                            Value="{Binding ThumbnailSize, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                    <TextBlock Text="&#xE80A;" FontFamily="{DynamicResource IconFont}" FontSize="16"
                               Foreground="{DynamicResource FgMutedBrush}" VerticalAlignment="Center"
                               Margin="4,0,0,0" ToolTip="Large thumbnails" />
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="9" Width="1" Fill="{DynamicResource BorderBrush}"
                           Margin="6,4" VerticalAlignment="Stretch" />

                <!-- Theme toggle + Settings + Prescan -->
                <StackPanel Grid.Column="10" Orientation="Horizontal" Margin="4,0">
                    <Button ToolTip="Toggle Theme (Ctrl+T)"
                            AutomationProperties.Name="Toggle Theme"
                            Style="{DynamicResource ToolbarButton}"
                            Command="{Binding ToggleThemeCommand}">
                        <TextBlock Text="&#xE706;" FontFamily="{DynamicResource IconFont}" FontSize="16" />
                    </Button>
                    <Button ToolTip="Prescan Folder (Ctrl+Shift+P)"
                            AutomationProperties.Name="Prescan Folder"
                            Style="{DynamicResource ToolbarButton}" Margin="2,0,0,0"
                            Click="PrescanButton_Click">
                        <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="16" />
                    </Button>
                    <Button ToolTip="Settings (Ctrl+,)"
                            AutomationProperties.Name="Settings"
                            Style="{DynamicResource ToolbarButton}" Margin="2,0,0,0"
                            Click="SettingsButton_Click">
                        <TextBlock Text="&#xE713;" FontFamily="{DynamicResource IconFont}" FontSize="16" />
                    </Button>
                    <Button ToolTip="About (F1)"
                            AutomationProperties.Name="About"
                            Style="{DynamicResource ToolbarButton}" Margin="2,0,0,0"
                            Click="AboutButton_Click">
                        <TextBlock Text="&#xE946;" FontFamily="{DynamicResource IconFont}" FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderTreeColumn" Width="240" MinWidth="0" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Folder tree -->
            <TreeView x:Name="FolderTree" Grid.Column="0"
                      SelectedItemChanged="FolderTree_SelectedItemChanged"
                      Padding="2" FontSize="13">
            </TreeView>

            <!-- Splitter -->
            <GridSplitter x:Name="FolderTreeSplitter" Grid.Column="1" Width="4"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Focusable="False" />

            <!-- Gallery -->
            <views:GalleryView x:Name="Gallery" Grid.Column="2" DataContext="{Binding}" />

            <!-- Loading overlay (fades in after 200ms delay) -->
            <Border x:Name="LoadingOverlay" Grid.Column="2" Background="#80000000"
                    Opacity="0" IsHitTestVisible="False" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x23F3;" FontSize="32" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Loading..." FontSize="16" Foreground="#CCCCCC"
                               HorizontalAlignment="Center" FontWeight="Medium" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Theme crossfade overlay -->
        <Image x:Name="ThemeCrossfadeOverlay" Grid.RowSpan="3" Panel.ZIndex="200"
               Stretch="None" Opacity="0" IsHitTestVisible="False" Visibility="Collapsed" />

        <!-- Escape toast -->
        <Border x:Name="EscapeToast" Grid.Row="1" Opacity="0" IsHitTestVisible="False"
                Background="#CC000000" CornerRadius="8" Padding="16,8"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,12" Panel.ZIndex="100">
            <TextBlock Text="Press Escape again to exit" FontSize="13"
                       Foreground="White" FontWeight="Medium" />
        </Border>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="2" Padding="8,4"
                   BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="SelectionCountText" FontSize="12"
                           Foreground="{DynamicResource FgMutedBrush}" Margin="12,0,0,0" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedItemInfo}" FontSize="12"
                           Foreground="{DynamicResource FgSecondaryBrush}" Margin="12,0,0,0" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ThumbnailLoadProgress}" FontSize="12"
                               Foreground="{DynamicResource FgMutedBrush}" Margin="8,0" />
                    <TextBlock x:Name="UpdateNotification" FontSize="12" Margin="8,0"
                               Foreground="{DynamicResource AccentBrush}" Cursor="Hand"
                               MouseDown="UpdateNotification_MouseDown"
                               Visibility="Collapsed" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource FgMutedBrush}" Margin="8,0">
                        <Run Text="Thumbnail: " />
                        <Run Text="{Binding ThumbnailSize, Mode=OneWay}" />
                        <Run Text="px" />
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
