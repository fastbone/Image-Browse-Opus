<Window x:Class="ImageBrowse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ImageBrowse.Views"
        xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
        xmlns:models="clr-namespace:ImageBrowse.Models"
        Title="Image Browse" Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="800" MinHeight="500"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Toggle folder -->
                    <ColumnDefinition Width="Auto" />  <!-- Back/Forward -->
                    <ColumnDefinition Width="*" />     <!-- Address bar -->
                    <ColumnDefinition Width="Auto" />  <!-- Sort -->
                    <ColumnDefinition Width="Auto" />  <!-- Thumbnail size -->
                    <ColumnDefinition Width="Auto" />  <!-- Theme toggle -->
                </Grid.ColumnDefinitions>

                <!-- Folder tree toggle -->
                <Button Grid.Column="0" Content="&#x1F4C1;" ToolTip="Toggle Folder Tree (Ctrl+Shift+F)"
                        Style="{DynamicResource ToolbarButton}" FontSize="16" Margin="2,0"
                        Command="{Binding ToggleFolderTreeCommand}" />

                <!-- Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0">
                    <Button x:Name="BackButton" Content="&#x25C0;" ToolTip="Back (Alt+Left)"
                            Style="{DynamicResource ToolbarButton}" FontSize="14"
                            Click="BackButton_Click" />
                    <Button x:Name="ForwardButton" Content="&#x25B6;" ToolTip="Forward (Alt+Right)"
                            Style="{DynamicResource ToolbarButton}" FontSize="14"
                            Click="ForwardButton_Click" />
                    <Button x:Name="UpButton" Content="&#x25B2;" ToolTip="Up (Alt+Up)"
                            Style="{DynamicResource ToolbarButton}" FontSize="14"
                            Click="UpButton_Click" />
                </StackPanel>

                <!-- Address bar -->
                <TextBox Grid.Column="2" x:Name="AddressBar"
                         Style="{DynamicResource AddressBar}"
                         Text="{Binding CurrentPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBar_KeyDown"
                         Margin="4,0" VerticalContentAlignment="Center" />

                <!-- Sort controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="4,0">
                    <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" />
                    <ComboBox x:Name="SortFieldCombo" Width="120" VerticalAlignment="Center"
                              SelectionChanged="SortFieldCombo_SelectionChanged">
                        <ComboBoxItem Content="Name" Tag="{x:Static models:SortField.FileName}" IsSelected="True" />
                        <ComboBoxItem Content="Date Modified" Tag="{x:Static models:SortField.DateModified}" />
                        <ComboBoxItem Content="Date Created" Tag="{x:Static models:SortField.DateCreated}" />
                        <ComboBoxItem Content="Date Taken" Tag="{x:Static models:SortField.DateTaken}" />
                        <ComboBoxItem Content="File Size" Tag="{x:Static models:SortField.FileSize}" />
                        <ComboBoxItem Content="Dimensions" Tag="{x:Static models:SortField.Dimensions}" />
                        <ComboBoxItem Content="File Type" Tag="{x:Static models:SortField.FileType}" />
                        <ComboBoxItem Content="Rating" Tag="{x:Static models:SortField.Rating}" />
                    </ComboBox>
                    <Button x:Name="SortDirectionButton" Content="&#x25B2;" ToolTip="Toggle Sort Direction"
                            Style="{DynamicResource ToolbarButton}" FontSize="12" Margin="2,0"
                            Command="{Binding ToggleSortDirectionCommand}" />
                    <Button Content="&#x21BA;" ToolTip="Reset to default sort"
                            Style="{DynamicResource ToolbarButton}" FontSize="14" Margin="2,0"
                            Visibility="{Binding HasCustomFolderSort, Converter={StaticResource BoolToVis}}"
                            Click="ResetSortButton_Click" />
                </StackPanel>

                <!-- Thumbnail size -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="4,0">
                    <Button Content="&#x2212;" ToolTip="Smaller Thumbnails (Ctrl+-)"
                            Style="{DynamicResource ToolbarButton}" FontSize="14"
                            Command="{Binding DecreaseThumbnailSizeCommand}" />
                    <TextBlock VerticalAlignment="Center" Margin="4,0"
                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding ThumbnailSize, Mode=OneWay}" /><Run Text="px" />
                    </TextBlock>
                    <Button Content="+" ToolTip="Larger Thumbnails (Ctrl++)"
                            Style="{DynamicResource ToolbarButton}" FontSize="14"
                            Command="{Binding IncreaseThumbnailSizeCommand}" />
                </StackPanel>

                <!-- Theme toggle + Settings + Prescan -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="4,0">
                    <Button Content="&#x263C;" ToolTip="Toggle Theme (Ctrl+T)"
                            Style="{DynamicResource ToolbarButton}" FontSize="18"
                            Command="{Binding ToggleThemeCommand}" />
                    <Button Content="&#x1F50D;" ToolTip="Prescan Folder (Ctrl+Shift+P)"
                            Style="{DynamicResource ToolbarButton}" FontSize="16" Margin="2,0,0,0"
                            Click="PrescanButton_Click" />
                    <Button Content="&#x2699;" ToolTip="Settings (Ctrl+,)"
                            Style="{DynamicResource ToolbarButton}" FontSize="18" Margin="2,0,0,0"
                            Click="SettingsButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderTreeColumn" Width="240" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Folder tree -->
            <TreeView x:Name="FolderTree" Grid.Column="0"
                      Visibility="{Binding IsFolderTreeVisible, Converter={StaticResource BoolToVis}}"
                      SelectedItemChanged="FolderTree_SelectedItemChanged"
                      Padding="2" FontSize="13">
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="{DynamicResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Visibility="{Binding IsFolderTreeVisible, Converter={StaticResource BoolToVis}}" />

            <!-- Gallery -->
            <views:GalleryView Grid.Column="2" DataContext="{Binding}" />

            <!-- Loading overlay -->
            <Border Grid.Column="2" Background="#80000000"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading..." FontSize="18" Foreground="White"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <StatusBar Grid.Row="2" Padding="8,4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="12" Margin="8,0">
                        <Run Text="Thumbnail: " />
                        <Run Text="{Binding ThumbnailSize, Mode=OneWay}" />
                        <Run Text="px" />
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
