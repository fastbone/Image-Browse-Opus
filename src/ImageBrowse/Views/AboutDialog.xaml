<Window x:Class="ImageBrowse.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Image Browse"
        Width="460" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="/Resources/app.ico" Width="64" Height="64"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel Margin="16,4,0,0" VerticalAlignment="Center">
                <TextBlock Text="Image Browse" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource FgPrimaryBrush}" />
                <TextBlock x:Name="VersionText" FontSize="13"
                           Foreground="{DynamicResource FgMutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- GitHub link -->
        <TextBlock Grid.Row="1" Margin="0,0,0,12">
            <Hyperlink x:Name="GithubLink" RequestNavigate="Hyperlink_RequestNavigate"
                       NavigateUri="https://github.com/fastbone/Image-Browse-Opus">
                github.com/fastbone/Image-Browse-Opus
            </Hyperlink>
        </TextBlock>

        <!-- Update section -->
        <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateStatusText" Grid.Column="0"
                           Text="Click to check for updates"
                           VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource FgPrimaryBrush}" />
                <Button x:Name="UpdateButton" Grid.Column="1"
                        Content="Check for Updates"
                        Style="{DynamicResource ToolbarButton}" Padding="12,6"
                        Click="UpdateButton_Click" />
            </Grid>
        </Border>

        <!-- Credits -->
        <TextBlock Grid.Row="3" Text="Built with" FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,6" />
        <TextBlock Grid.Row="4" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource FgSecondaryBrush}" VerticalAlignment="Top"
                   LineHeight="22">
            Magick.NET (ImageMagick) · MetadataExtractor · CommunityToolkit.Mvvm ·
            VirtualizingWrapPanel · Velopack · Microsoft.Data.Sqlite · .NET 8 / WPF
        </TextBlock>

        <!-- Close button -->
        <Button Grid.Row="5" Content="Close" Width="90"
                HorizontalAlignment="Right"
                Style="{DynamicResource ToolbarButton}" Padding="8,8"
                Click="Close_Click" IsCancel="True" />
    </Grid>
</Window>
