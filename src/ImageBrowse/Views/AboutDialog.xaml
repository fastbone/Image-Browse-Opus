<Window x:Class="ImageBrowse.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Image Browse"
        Width="460" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="/Resources/app.ico" Width="64" Height="64"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel Margin="16,4,0,0" VerticalAlignment="Center">
                <TextBlock Text="Image Browse" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource FgPrimaryBrush}" />
                <TextBlock x:Name="VersionText" FontSize="13"
                           Foreground="{DynamicResource FgMutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- GitHub link with accent color -->
        <TextBlock Grid.Row="1" Margin="0,0,0,16">
            <Hyperlink x:Name="GithubLink" RequestNavigate="Hyperlink_RequestNavigate"
                       NavigateUri="https://fastbone.github.io/Image-Browse-Opus/"
                       Foreground="{DynamicResource AccentBrush}"
                       TextDecorations="None">
                <Hyperlink.Style>
                    <Style TargetType="Hyperlink">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Hyperlink.Style>
                fastbone.github.io/Image-Browse-Opus
            </Hyperlink>
        </TextBlock>

        <!-- Update section card -->
        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="UpdateStatusText" Grid.Column="0"
                           Text="Click to check for updates"
                           VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource FgPrimaryBrush}" />
                <Button x:Name="UpdateButton" Grid.Column="1"
                        Content="Check for Updates"
                        Style="{DynamicResource AccentButton}" Padding="12,6"
                        Click="UpdateButton_Click" />
            </Grid>
        </Border>

        <!-- Credits card -->
        <Border Grid.Row="3" Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="Built with" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource FgSecondaryBrush}"
                           LineHeight="22">
                    Magick.NET (ImageMagick) · LibVLCSharp (LibVLC) · MetadataExtractor · CommunityToolkit.Mvvm ·
                    VirtualizingWrapPanel · Velopack · Microsoft.Data.Sqlite · .NET 10 / WPF
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="5" Content="Close" Width="90"
                HorizontalAlignment="Right"
                Style="{DynamicResource ToolbarButton}" Padding="8,8"
                Click="Close_Click" IsCancel="True" />
    </Grid>
</Window>
