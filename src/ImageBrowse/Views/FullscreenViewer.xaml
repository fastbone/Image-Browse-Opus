<Window x:Class="ImageBrowse.Views.FullscreenViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Image Viewer"
        WindowStyle="None" WindowState="Maximized"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Black" Cursor="None"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        MouseMove="Window_MouseMove"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Main image display with crossfade support -->
        <ScrollViewer x:Name="ImageScroller"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Hidden"
                      Background="Black"
                      IsManipulationEnabled="True"
                      ManipulationStarting="ImageScroller_ManipulationStarting"
                      ManipulationDelta="ImageScroller_ManipulationDelta"
                      ManipulationCompleted="ImageScroller_ManipulationCompleted"
                      ScrollChanged="ImageScroller_ScrollChanged"
                      MouseLeftButtonDown="ImageScroller_MouseLeftButtonDown"
                      MouseLeftButtonUp="ImageScroller_MouseLeftButtonUp"
                      MouseMove="ImageScroller_MouseMove">
            <Grid x:Name="ImageContainer"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Background image for crossfade (old image) -->
                <Image x:Name="BackImage"
                       Stretch="Uniform" Opacity="0"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="BackImageScale" ScaleX="1" ScaleY="1" />
                    </Image.RenderTransform>
                </Image>
                <!-- Foreground image (current) -->
                <Image x:Name="DisplayImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                    </Image.RenderTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Video player (hidden when viewing images) -->
        <vlc:VideoView x:Name="VideoView" Visibility="Collapsed" Background="Black">
            <Grid Background="Transparent">
                <!-- Video control bar (bottom, auto-hides) -->
                <Border x:Name="VideoControlBar" Opacity="0" IsHitTestVisible="True"
                        Background="#CC000000" VerticalAlignment="Bottom"
                        Height="50" Cursor="Arrow"
                        MouseEnter="VideoControlBar_MouseEnter"
                        MouseLeave="VideoControlBar_MouseLeave">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Play/Pause button -->
                        <Button x:Name="PlayPauseButton" Grid.Column="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontFamily="{DynamicResource IconFont}"
                                FontSize="20" Width="36" Height="36" Cursor="Hand"
                                Click="PlayPause_Click" VerticalAlignment="Center">
                            <TextBlock x:Name="PlayPauseIcon" Text="&#xE769;"
                                       FontFamily="{DynamicResource IconFont}" FontSize="20"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Current time -->
                        <TextBlock x:Name="VideoTimeText" Grid.Column="1"
                                   Text="0:00" FontSize="12" Foreground="#CCC"
                                   VerticalAlignment="Center" Margin="8,0" />

                        <!-- Seek slider -->
                        <Slider x:Name="VideoSeekBar" Grid.Column="2"
                                Minimum="0" Maximum="1000"
                                VerticalAlignment="Center" Margin="4,0"
                                IsMoveToPointEnabled="True" Cursor="Hand"
                                PreviewMouseLeftButtonDown="SeekBar_PreviewMouseDown"
                                PreviewMouseLeftButtonUp="SeekBar_PreviewMouseUp"
                                ValueChanged="SeekBar_ValueChanged" />

                        <!-- Duration -->
                        <TextBlock x:Name="VideoDurationText" Grid.Column="3"
                                   Text="0:00" FontSize="12" Foreground="#CCC"
                                   VerticalAlignment="Center" Margin="8,0" />

                        <!-- Playback speed -->
                        <Border Grid.Column="4" Background="#44FFFFFF" CornerRadius="4"
                                Padding="6,2" Margin="4,0" Cursor="Hand"
                                MouseLeftButtonDown="SpeedButton_Click"
                                MouseRightButtonDown="SpeedButton_RightClick">
                            <TextBlock x:Name="SpeedText" Text="1.0x" FontSize="11"
                                       Foreground="White" VerticalAlignment="Center" />
                        </Border>

                        <!-- Expand/Fit toggle -->
                        <Button x:Name="VideoFitButton" Grid.Column="5"
                                Background="Transparent" BorderThickness="0"
                                Width="36" Height="36" Cursor="Hand"
                                Click="VideoFitToggle_Click" VerticalAlignment="Center">
                            <TextBlock x:Name="VideoFitIcon" Text="&#xE740;"
                                       FontFamily="{DynamicResource IconFont}" FontSize="16"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Volume -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="MuteButton" Background="Transparent" BorderThickness="0"
                                    Width="30" Height="30" Cursor="Hand" Click="Mute_Click">
                                <TextBlock x:Name="VolumeIcon" Text="&#xE767;"
                                           FontFamily="{DynamicResource IconFont}" FontSize="16"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                            <Slider x:Name="VolumeSlider" Width="80" Minimum="0" Maximum="100" Value="100"
                                    VerticalAlignment="Center" IsMoveToPointEnabled="True" Cursor="Hand"
                                    ValueChanged="VolumeSlider_ValueChanged" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Video mini-map for interactive zoom (inside VideoView for airspace) -->
                <Border x:Name="VideoMiniMapPanel" Visibility="Collapsed"
                        Background="#AA000000" CornerRadius="8"
                        Width="200" Height="130" Padding="4"
                        Margin="16,16,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Cursor="Hand"
                        MouseLeftButtonDown="VideoMiniMap_MouseDown"
                        MouseMove="VideoMiniMap_MouseMove"
                        MouseLeftButtonUp="VideoMiniMap_MouseUp">
                    <Canvas x:Name="VideoMiniMapCanvas" ClipToBounds="True">
                        <Image x:Name="VideoMiniMapImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="LowQuality" />
                        <Rectangle x:Name="VideoMiniMapViewport"
                                   Stroke="#CCFFFFFF" StrokeThickness="1.5"
                                   Fill="#22FFFFFF" RadiusX="1" RadiusY="1" />
                    </Canvas>
                </Border>

                <!-- Video nav arrows (inside VideoView for airspace) -->
                <Border x:Name="VideoNavLeft" Width="120" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Background="Transparent" Opacity="0" IsHitTestVisible="True" Cursor="Hand"
                        MouseEnter="VideoNavLeft_MouseEnter" MouseLeave="VideoNavZone_MouseLeave"
                        MouseLeftButtonDown="NavLeft_Click">
                    <TextBlock Text="&#xE76B;" FontFamily="{DynamicResource IconFont}" FontSize="28"
                               Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="VideoNavRight" Width="120" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Background="Transparent" Opacity="0" IsHitTestVisible="True" Cursor="Hand"
                        MouseEnter="VideoNavRight_MouseEnter" MouseLeave="VideoNavZone_MouseLeave"
                        MouseLeftButtonDown="NavRight_Click">
                    <TextBlock Text="&#xE76C;" FontFamily="{DynamicResource IconFont}" FontSize="28"
                               Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </vlc:VideoView>

        <!-- Left nav hover zone -->
        <Border x:Name="NavLeft" Width="120" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Opacity="0" IsHitTestVisible="True" Cursor="Hand"
                MouseEnter="NavLeft_MouseEnter" MouseLeave="NavZone_MouseLeave"
                MouseLeftButtonDown="NavLeft_Click">
            <TextBlock Text="&#xE76B;" FontFamily="{DynamicResource IconFont}" FontSize="28"
                       Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Right nav hover zone -->
        <Border x:Name="NavRight" Width="120" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Opacity="0" IsHitTestVisible="True" Cursor="Hand"
                MouseEnter="NavRight_MouseEnter" MouseLeave="NavZone_MouseLeave"
                MouseLeftButtonDown="NavRight_Click">
            <TextBlock Text="&#xE76C;" FontFamily="{DynamicResource IconFont}" FontSize="28"
                       Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Info overlay (press I to toggle) - redesigned with label:value layout -->
        <Border x:Name="InfoPanel" Opacity="0" IsHitTestVisible="False"
                Background="#CC000000" CornerRadius="12"
                Padding="20" Margin="20"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                MaxWidth="400">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Direction="270" Color="Black" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="InfoFileName" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" TextWrapping="Wrap" Margin="0,0,0,12" />

                <!-- File info group -->
                <Grid x:Name="InfoDimensionsGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Dimensions" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoDimensions" Grid.Column="1" FontSize="12" Foreground="#DDD" />
                </Grid>
                <Grid x:Name="InfoFileSizeGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Size" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoFileSize" Grid.Column="1" FontSize="12" Foreground="#DDD" />
                </Grid>

                <!-- Separator -->
                <Rectangle Height="1" Fill="#333" Margin="0,8" />

                <!-- Date info -->
                <Grid x:Name="InfoDateTakenGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Taken" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoDateTaken" Grid.Column="1" FontSize="12" Foreground="#DDD" />
                </Grid>
                <Grid x:Name="InfoDateModifiedGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Modified" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoDateModified" Grid.Column="1" FontSize="12" Foreground="#DDD" />
                </Grid>

                <!-- Separator -->
                <Rectangle x:Name="CameraSeparator" Height="1" Fill="#333" Margin="0,8" />

                <!-- Camera info -->
                <Grid x:Name="InfoCameraGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Camera" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoCamera" Grid.Column="1" FontSize="12" Foreground="#DDD" TextWrapping="Wrap" />
                </Grid>
                <Grid x:Name="InfoLensGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Lens" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoLens" Grid.Column="1" FontSize="12" Foreground="#DDD" TextWrapping="Wrap" />
                </Grid>
                <Grid x:Name="InfoExposureGrid" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Exposure" FontSize="12" Foreground="#888" />
                    <TextBlock x:Name="InfoExposure" Grid.Column="1" FontSize="12" Foreground="#DDD" TextWrapping="Wrap" />
                </Grid>

                <!-- Rating -->
                <helpers:RatingStarsControl x:Name="InfoRatingStars" StarSize="14" Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <!-- Filmstrip thumbnail strip (bottom, auto-show on mouse proximity) -->
        <Border x:Name="FilmstripPanel" Opacity="0" IsHitTestVisible="True"
                Background="#CC000000" VerticalAlignment="Bottom"
                Height="86" Cursor="Arrow"
                MouseEnter="Filmstrip_MouseEnter" MouseLeave="Filmstrip_MouseLeave">
            <ListBox x:Name="FilmstripList"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     SelectionMode="Single"
                     SelectionChanged="FilmstripList_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="3,8" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="thumbBorder"
                                            BorderBrush="Transparent" BorderThickness="2"
                                            CornerRadius="4" Background="Transparent" Opacity="0.5">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="thumbBorder" Property="BorderBrush" Value="White" />
                                            <Setter TargetName="thumbBorder" Property="Opacity" Value="1" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="thumbBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="3" ClipToBounds="True">
                            <Image Source="{Binding Thumbnail}" Width="60" Height="60"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="LowQuality" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Position indicator (bottom center, auto-fades, shifts up when filmstrip visible) -->
        <Border x:Name="PositionIndicator" Opacity="0" IsHitTestVisible="False"
                Background="#88000000" CornerRadius="14"
                Padding="18,8" Margin="0,0,0,30"
                HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <TextBlock x:Name="PositionText" FontSize="14" Foreground="White"
                       FontWeight="Medium" />
        </Border>

        <!-- Mini-map when zoomed (bottom-right) -->
        <Border x:Name="MiniMapPanel" Visibility="Collapsed" IsHitTestVisible="True"
                Background="#AA000000" CornerRadius="8"
                Width="160" Height="120"
                Margin="0,0,16,16" Padding="4"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Cursor="Hand"
                MouseLeftButtonDown="MiniMap_MouseLeftButtonDown"
                MouseMove="MiniMap_MouseMove"
                MouseLeftButtonUp="MiniMap_MouseLeftButtonUp">
            <Canvas x:Name="MiniMapCanvas" ClipToBounds="True">
                <Image x:Name="MiniMapImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality" />
                <Rectangle x:Name="MiniMapViewport"
                           Stroke="#CCFFFFFF" StrokeThickness="1.5"
                           Fill="#22FFFFFF" RadiusX="1" RadiusY="1" />
            </Canvas>
        </Border>

        <!-- Zoom indicator (top right, auto-fades) -->
        <Border x:Name="ZoomIndicator" Opacity="0" IsHitTestVisible="False"
                Background="#88000000" CornerRadius="8"
                Padding="12,6" Margin="20"
                HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock x:Name="ZoomText" FontSize="13" Foreground="White" />
        </Border>
    </Grid>
</Window>
