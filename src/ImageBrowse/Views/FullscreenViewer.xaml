<Window x:Class="ImageBrowse.Views.FullscreenViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
        Title="Image Viewer"
        WindowStyle="None" WindowState="Maximized"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="Black" Cursor="None"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        MouseMove="Window_MouseMove"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3" />
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Main image display -->
        <ScrollViewer x:Name="ImageScroller"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Hidden"
                      Background="Black">
            <Grid x:Name="ImageContainer"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="DisplayImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                    </Image.RenderTransform>
                </Image>
            </Grid>
        </ScrollViewer>

        <!-- Info overlay (press I to toggle) -->
        <Border x:Name="InfoPanel" Opacity="0" IsHitTestVisible="False"
                Background="#CC000000" CornerRadius="8"
                Padding="16" Margin="20"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                MaxWidth="360">
            <StackPanel>
                <TextBlock x:Name="InfoFileName" FontSize="16" FontWeight="SemiBold"
                           Foreground="White" TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock x:Name="InfoDimensions" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoFileSize" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoDateTaken" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoDateModified" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoCamera" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoLens" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoExposure" FontSize="13" Foreground="#CCC" Margin="0,2" />
                <TextBlock x:Name="InfoRating" FontSize="14" Foreground="#FFD700" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Position indicator (bottom center, auto-fades) -->
        <Border x:Name="PositionIndicator" Opacity="0" IsHitTestVisible="False"
                Background="#88000000" CornerRadius="12"
                Padding="16,8" Margin="0,0,0,30"
                HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <TextBlock x:Name="PositionText" FontSize="14" Foreground="White"
                       FontWeight="Medium" />
        </Border>

        <!-- Zoom indicator (top right, auto-fades) -->
        <Border x:Name="ZoomIndicator" Opacity="0" IsHitTestVisible="False"
                Background="#88000000" CornerRadius="8"
                Padding="12,6" Margin="20"
                HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock x:Name="ZoomText" FontSize="13" Foreground="White" />
        </Border>
    </Grid>
</Window>
