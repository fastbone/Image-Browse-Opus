<UserControl x:Class="ImageBrowse.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
             x:Name="GalleryRoot"
             Focusable="True">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />

        <!-- Shimmer style for loading placeholders (pulsing opacity) -->
        <Style x:Key="ShimmerRectangle" TargetType="Rectangle">
            <Setter Property="RadiusX" Value="4" />
            <Setter Property="RadiusY" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Fill" Value="{DynamicResource BgHoverBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsThumbnailLoading}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="ShimmerStory">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1" Duration="0:0:0.8" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ShimmerStory" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Empty state overlay -->
        <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="&#xEB9F;" FontFamily="{DynamicResource IconFont}"
                       FontSize="48" HorizontalAlignment="Center"
                       Foreground="{DynamicResource FgMutedBrush}" Margin="0,0,0,12" />
            <TextBlock Text="No media in this folder" FontSize="16" FontWeight="Medium"
                       Foreground="{DynamicResource FgSecondaryBrush}" HorizontalAlignment="Center"
                       Margin="0,0,0,6" />
            <TextBlock Text="Browse to a folder containing images or videos"
                       FontSize="13" Foreground="{DynamicResource FgMutedBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

    <ListBox x:Name="GalleryListBox"
             ItemsSource="{Binding SortedImages}"
             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             SelectionMode="Extended"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             VirtualizingPanel.CacheLength="2,2"
             VirtualizingPanel.CacheLengthUnit="Page"
             HorizontalContentAlignment="Center"
             VerticalContentAlignment="Top"
             KeyboardNavigation.DirectionalNavigation="Contained"
             PreviewKeyDown="GalleryListBox_PreviewKeyDown"
             KeyDown="GalleryListBox_KeyDown"
             MouseDoubleClick="GalleryListBox_MouseDoubleClick">

        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <vwp:VirtualizingWrapPanel Orientation="Horizontal"
                                           SpacingMode="Uniform" />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>

        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="border" Background="Transparent"
                                    CornerRadius="8" Padding="4" SnapsToDevicePixels="True"
                                    BorderBrush="Transparent" BorderThickness="2"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard x:Name="HoverIn">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="border"
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.7" To="1" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="border"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1" Duration="0:0:0.15" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource BgHoverBrush}" />
                                    <Setter TargetName="border" Property="BorderBrush"
                                            Value="{DynamicResource BorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource BgSelectedBrush}" />
                                    <Setter TargetName="border" Property="BorderBrush"
                                            Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ListBox.ItemContainerStyle>

        <ListBox.ItemTemplate>
            <DataTemplate>
                <Grid Width="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}"
                      Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Thumbnail -->
                    <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="8"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Parent folder up-arrow icon -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsParentFolder}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="&#xE74A;" FontFamily="{DynamicResource IconFont}"
                                           FontSize="40" Foreground="{DynamicResource FgMutedBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text=".." FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource FgMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Regular thumbnail (hidden for parent folder) -->
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsParentFolder}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <!-- Shimmer loading placeholder -->
                            <Rectangle Style="{StaticResource ShimmerRectangle}" />

                            <!-- Video play icon overlay (centered) -->
                            <Border Background="#88000000" Width="36" Height="36"
                                    CornerRadius="18"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="&#xE768;" FontFamily="{DynamicResource IconFont}"
                                           FontSize="16" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="2,0,0,0" />
                            </Border>

                            <!-- Video duration badge (bottom-right) -->
                            <Border Background="#CC000000" CornerRadius="4"
                                    Padding="5,2" Margin="0,0,6,6"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding DurationDisplay}" FontSize="10"
                                           Foreground="White" FontWeight="Medium" />
                            </Border>

                            <!-- Tag indicator -->
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="8" Padding="5,2" Margin="6"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Visibility="{Binding IsTagged,
                                        Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE1CB;" FontFamily="{DynamicResource IconFont}"
                                           FontSize="10" Foreground="White" />
                            </Border>

                            <!-- Rating overlay -->
                            <helpers:RatingStarsControl Rating="{Binding Rating}"
                                       StarSize="10"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Margin="6,0,0,6" />

                            <!-- Folder badge overlay (pill shape with icon) -->
                            <Border Background="#CC000000" CornerRadius="10"
                                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                    Padding="10,4" Margin="0,0,0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsFolder}" Value="True" />
                                                    <Condition Binding="{Binding IsParentFolder}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED41;" FontFamily="{DynamicResource IconFont}"
                                               FontSize="11" Foreground="White" Margin="0,0,4,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Folder" FontSize="11" Foreground="White"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- File name -->
                    <TextBlock Grid.Row="1" Text="{Binding FileName}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               MaxWidth="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}" />

                    <!-- Subtitle: dimensions/size for images, image count for folders -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding SubtitleDisplay, Mode=OneWay}"
                               FontSize="10"
                               Foreground="{DynamicResource FgMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,1,0,0"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
    </Grid>
</UserControl>
