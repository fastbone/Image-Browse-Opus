<UserControl x:Class="ImageBrowse.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:helpers="clr-namespace:ImageBrowse.Helpers"
             x:Name="GalleryRoot"
             Focusable="True">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:RatingToStarsConverter x:Key="RatingToStars" />
    </UserControl.Resources>

    <ListBox x:Name="GalleryListBox"
             ItemsSource="{Binding SortedImages}"
             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             SelectionMode="Extended"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             VirtualizingPanel.CacheLength="2,2"
             VirtualizingPanel.CacheLengthUnit="Page"
             HorizontalContentAlignment="Center"
             VerticalContentAlignment="Top"
             KeyDown="GalleryListBox_KeyDown"
             MouseDoubleClick="GalleryListBox_MouseDoubleClick">

        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <vwp:VirtualizingWrapPanel Orientation="Horizontal"
                                           SpacingMode="Uniform" />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>

        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="border" Background="Transparent"
                                    CornerRadius="6" Padding="4" SnapsToDevicePixels="True">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource BgHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource BgSelectedBrush}" />
                                    <Setter TargetName="border" Property="BorderBrush"
                                            Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="border" Property="BorderThickness" Value="2" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ListBox.ItemContainerStyle>

        <ListBox.ItemTemplate>
            <DataTemplate>
                <Grid Width="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}"
                      Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Thumbnail -->
                    <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="4"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <!-- Loading indicator -->
                            <TextBlock Text="..." FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource FgMutedBrush}"
                                       Visibility="{Binding IsThumbnailLoading,
                                           Converter={StaticResource BoolToVis}}" />

                            <!-- Tag indicator -->
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="3" Padding="3,1" Margin="4"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Visibility="{Binding IsTagged,
                                        Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="T" FontSize="10" FontWeight="Bold"
                                           Foreground="White" />
                            </Border>

                            <!-- Rating overlay -->
                            <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                       FontSize="11" Foreground="#FFD700"
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Margin="4,0,0,4" />

                            <!-- Folder badge overlay -->
                            <Border Background="#AA000000" CornerRadius="0,0,4,4"
                                    VerticalAlignment="Bottom" Padding="4,2"
                                    Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="📁 Folder" FontSize="10" Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- File name -->
                    <TextBlock Grid.Row="1" Text="{Binding FileName}"
                               FontSize="11" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               MaxWidth="{Binding DataContext.ThumbnailSize, ElementName=GalleryRoot}" />

                    <!-- Subtitle: dimensions/size for images, image count for folders -->
                    <TextBlock Grid.Row="2"
                               Text="{Binding SubtitleDisplay, Mode=OneWay}"
                               FontSize="10"
                               Foreground="{DynamicResource FgMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,1,0,0"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
