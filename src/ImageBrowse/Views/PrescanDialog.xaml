<Window x:Class="ImageBrowse.Views.PrescanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prescan Folder"
        Width="560" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Folder -->
        <TextBlock Grid.Row="0" Text="Folder to Prescan" FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,6" />
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderBox"
                     Style="{DynamicResource AddressBar}"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0"
                    Style="{DynamicResource ToolbarButton}" Padding="12,6"
                    Click="BrowseFolder_Click" />
        </Grid>

        <!-- Depth -->
        <TextBlock Grid.Row="2" Text="Scan Depth" FontWeight="SemiBold" FontSize="13"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,6" />
        <ComboBox x:Name="DepthCombo" Grid.Row="3" Width="200" HorizontalAlignment="Left"
                  Margin="0,0,0,16" SelectedIndex="2">
            <ComboBoxItem Content="This folder only" Tag="0" />
            <ComboBoxItem Content="1 level deep" Tag="1" />
            <ComboBoxItem Content="2 levels deep" Tag="2" />
            <ComboBoxItem Content="5 levels deep" Tag="5" />
            <ComboBoxItem Content="Unlimited" Tag="-1" />
        </ComboBox>

        <!-- Progress -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="4" Height="20" Minimum="0" Maximum="100"
                     Margin="0,0,0,8" />

        <!-- Stats -->
        <TextBlock x:Name="CurrentFolderText" Grid.Row="5" FontSize="11"
                   Foreground="{DynamicResource FgMutedBrush}" TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,4" />
        <TextBlock x:Name="StatsText" Grid.Row="6" FontSize="12"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,8" />

        <!-- Status -->
        <TextBlock x:Name="StatusLabel" Grid.Row="7" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Bottom"
                   Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="Start Prescan" Width="120" Margin="0,0,8,0"
                    Style="{DynamicResource ToolbarButton}" Padding="8,8"
                    Click="StartButton_Click" />
            <Button x:Name="CloseButton" Content="Close" Width="80"
                    Style="{DynamicResource ToolbarButton}" Padding="8,8"
                    Click="CloseButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
