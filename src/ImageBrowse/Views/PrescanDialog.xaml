<Window x:Class="ImageBrowse.Views.PrescanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prescan Folder"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Dialog header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="&#xE721;" FontFamily="{DynamicResource IconFont}" FontSize="22"
                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBlock Text="Prescan Folder" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Folder selection card -->
        <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Folder to Prescan" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FolderBox"
                             Style="{DynamicResource AddressBar}"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="1" Content="Browse..." Margin="8,0,0,0"
                            Style="{DynamicResource ToolbarButton}" Padding="12,6"
                            Click="BrowseFolder_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Depth card -->
        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" CornerRadius="8"
                Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Scan Depth" FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,8" />
                <ComboBox x:Name="DepthCombo" Width="200" HorizontalAlignment="Left" SelectedIndex="2">
                    <ComboBoxItem Content="This folder only" Tag="0" />
                    <ComboBoxItem Content="1 level deep" Tag="1" />
                    <ComboBoxItem Content="2 levels deep" Tag="2" />
                    <ComboBoxItem Content="5 levels deep" Tag="5" />
                    <ComboBoxItem Content="Unlimited" Tag="-1" />
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Progress -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="3" Height="6" Minimum="0" Maximum="100"
                     Margin="0,0,0,8" />

        <!-- Stats -->
        <TextBlock x:Name="CurrentFolderText" Grid.Row="4" FontSize="11"
                   Foreground="{DynamicResource FgMutedBrush}" TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,4" />
        <TextBlock x:Name="StatsText" Grid.Row="5" FontSize="12"
                   Foreground="{DynamicResource FgPrimaryBrush}" Margin="0,0,0,8" />

        <!-- Status -->
        <TextBlock x:Name="StatusLabel" Grid.Row="6" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Bottom"
                   Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="Start Prescan" Width="130" Margin="0,0,8,0"
                    Style="{DynamicResource AccentButton}" Padding="12,8"
                    Click="StartButton_Click" />
            <Button x:Name="CloseButton" Content="Close" Width="80"
                    Style="{DynamicResource ToolbarButton}" Padding="8,8"
                    Click="CloseButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
