<Window x:Class="ImageBrowse.Views.UpdatePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE895;" FontFamily="{DynamicResource IconFont}" FontSize="24"
                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBlock Text="Update Available" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource FgPrimaryBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource FgPrimaryBrush}" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Ignore" Width="80"
                    Style="{DynamicResource ToolbarButton}" Padding="8,8"
                    Click="Ignore_Click" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Install on Close" Width="120"
                    Style="{DynamicResource ToolbarButton}" Padding="8,8"
                    Click="InstallOnClose_Click" Margin="0,0,8,0" />
            <Button Content="Install Now" Width="100"
                    Style="{DynamicResource AccentButton}" Padding="12,8"
                    Click="InstallNow_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
